#!/usr/bin/env python3
"""
ki-wizard.py — generates fab deliverables from a KiCad project.

Usage:
    python ki-wizard.py [options] <projectname>

The project name should be the base name of the .kicad_sch / .kicad_pcb
files, without extension. Quote it if it contains spaces.

2026-01-13: added JLC outputs
2026-06-09: argparse; provenance file; --include-source
2026-07-08: gerbview HTML layer viewer
"""

import argparse
import csv
import hashlib
import re
import shutil
import subprocess
import sys
import zipfile
from datetime import datetime
from pathlib import Path

VERSION = "2.2"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def run(cmd: list[str]) -> None:
    """Run a command, printing it first, and exit on non-zero return code."""
    print(">>", " ".join(cmd))
    result = subprocess.run(cmd)
    if result.returncode != 0:
        sys.exit(f"Command failed with exit code {result.returncode}: {' '.join(cmd)}")


def zip_directory(source_dir: Path, zip_path: Path) -> None:
    """Zip source_dir into zip_path, preserving internal relative paths."""
    with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
        for file in source_dir.rglob("*"):
            if file.is_file():
                zf.write(file, file.relative_to(source_dir.parent))


def sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def convert_cpl_jlc(input_path: Path, output_path: Path) -> None:
    """
    Convert a KiCad positions CSV to JLC CPL format.
    Drops Val and Package columns; renames remaining columns to JLC names.
    """

    column_map = {
        "Ref":  "Designator",
        "PosX": "Mid X",
        "PosY": "Mid Y",
        "Rot":  "Rotation",
        "Side": "Layer",
    }
    keep = list(column_map.keys())

    with input_path.open(newline="") as infile, \
         output_path.open("w", newline="") as outfile:

        reader = csv.DictReader(infile)
        writer = csv.DictWriter(outfile, fieldnames=list(column_map.values()))
        writer.writeheader()

        for row in reader:
            writer.writerow({column_map[col]: row[col] for col in keep})

    print(f"Saved: {output_path}")


def write_provenance(out: Path, sch: Path, pcb: Path, timestamp: str) -> None:
    """Write provenance.txt recording source file identities for this build."""
    lines = [
        f"ki-wizard version: {VERSION}",
        f"timestamp: {timestamp}",
        "",
        "source files:",
        f"  {sch}",
        f"    sha256: {sha256(sch)}",
        f"  {pcb}",
        f"    sha256: {sha256(pcb)}",
    ]
    prov = out / "provenance.txt"
    prov.write_text("\n".join(lines) + "\n")
    print(f"Saved: {prov}")


def bundle_source(out: Path, proj_file: str, proj_name: str) -> None:
    """Zip minimal source files (.kicad_pcb, .kicad_sch, .kicad_pro, .pretty/) into the output folder."""
    source_zip = out / f"{proj_name}_source.zip"
    proj_dir = Path(proj_file).parent if Path(proj_file).parent != Path(".") else Path(".")

    candidates = [
        Path(f"{proj_file}.kicad_pcb"),
        Path(f"{proj_file}.kicad_sch"),
        Path(f"{proj_file}.kicad_pro"),
    ]
    # Include any additional .kicad_sch sheets in the same directory
    candidates += [p for p in proj_dir.glob("*.kicad_sch") if p not in candidates]
    # Include custom footprint libraries (.pretty directories)
    pretty_dirs = list(proj_dir.glob("*.pretty"))

    with zipfile.ZipFile(source_zip, "w", zipfile.ZIP_DEFLATED) as zf:
        for path in candidates:
            if path.exists():
                zf.write(path, path.name)
        for pretty in pretty_dirs:
            for file in pretty.rglob("*"):
                if file.is_file():
                    zf.write(file, file.relative_to(proj_dir))

    print(f"Saved: {source_zip}")


# ---------------------------------------------------------------------------
# Gerbview: interactive HTML layer viewer
# ---------------------------------------------------------------------------

# (label, color, default_on, opacity) -- order is the physical stack from
# front surface to back surface; drives both the SVG export layer list and
# the viewer's default (unflipped) z-order.
GERBVIEW_LAYERS = [
    ("Edge.Cuts",    "D0D2CD", True,  1.0),
    ("F.Silkscreen", "F2EDA1", True,  1.0),
    ("F.Cu",         "C83434", True,  1.0),
    ("F.Paste",      "B4A09A", False, 1.0),
    ("F.Mask",       "D864FF", True,  1.0),
    ("In1.Cu",       "E8A33D", False, 0.5),
    ("In2.Cu",       "3DA5E8", False, 0.5),
    ("B.Cu",         "3D8CE8", False, 1.0),
    ("B.Paste",      "8C7A74", False, 1.0),
    ("B.Silkscreen", "A8A468", False, 1.0),
]

GERBVIEW_TEMPLATE = """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>__PROJ_NAME__ -- Gerber Layer Viewer</title>
<style>
  html, body { margin: 0; height: 100%; background: #1a1a1a; color: #ccc; font-family: sans-serif; }
  body { display: flex; }
  #sidebar { width: 160px; min-width: 160px; padding: 16px 12px; background: #111; display: flex; flex-direction: column; gap: 6px; }
  #sidebar h2 { margin: 0 0 12px; font-size: 13px; text-transform: uppercase; letter-spacing: .08em; color: #888; }
  .layer-label { display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; }
  .layer-label::before { content:""; display:inline-block; width:12px; height:12px; border-radius:2px; background:var(--c); flex-shrink:0; }
  .layer-label input { display:none; }
  .layer-label.off { opacity: 0.4; }
  #flip-row { margin-top: 16px; padding-top: 12px; border-top: 1px solid #333; }
  #flip-row label { display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; }
  #board { flex: 1; position: relative; padding: 20px; box-sizing: border-box; overflow: hidden; }
  #stack { position: relative; width: 100%; height: 100%; transition: transform 0.3s; }
  #stack.flipped { transform: scaleX(-1); }
  .pcb-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
  .pcb-layer.hidden { display: none; }
</style>
</head>
<body>
<div id="sidebar">
  <h2>Layers</h2>
  __CHECKBOXES__
  <div id="flip-row">
    <label><input type="checkbox" id="flip-toggle" onchange="toggleFlip(this)"> Flip board view</label>
  </div>
</div>
<div id="board">
  <div id="stack">
    __OBJECTS__
  </div>
</div>
<script>
var LAYER_ORDER = __LAYER_ORDER_JS__;
var flipped = false;

function toggleLayer(cb) {
  var id = 'layer-' + cb.dataset.layer.replace(/\\./g, '-');
  document.getElementById(id).classList.toggle('hidden', !cb.checked);
  cb.closest('.layer-label').classList.toggle('off', !cb.checked);
}

function applyZOrder() {
  // Front-side layers sit on top in the default (front) view; flipping
  // makes the back-side layers rise to the top instead, as if the
  // board were turned over to look at its other face.
  var n = LAYER_ORDER.length;
  LAYER_ORDER.forEach(function(id, i) {
    var el = document.getElementById('layer-' + id);
    if (el) el.style.zIndex = flipped ? i : (n - 1 - i);
  });
}

function toggleFlip(cb) {
  flipped = cb.checked;
  document.getElementById('stack').classList.toggle('flipped', flipped);
  applyZOrder();
}

// Crop every layer to the Edge.Cuts bounding box -- KiCad's own
// "fit to board" canvas can include off-board silkscreen art, so we
// compute the true board extent ourselves and share it across layers.
// Each layer is cropped independently on its own load event, since
// hidden (display:none) layers can finish loading later or out of order.
function cropToViewBox(obj, vb) {
  var svg = obj.contentDocument && obj.contentDocument.querySelector('svg');
  if (!svg) return false;
  svg.setAttribute('viewBox', vb);
  svg.setAttribute('width', '100%');
  svg.setAttribute('height', '100%');
  return true;
}

function applyCropToAllLayers(vb) {
  document.querySelectorAll('.pcb-layer').forEach(function(obj) {
    if (!cropToViewBox(obj, vb)) {
      obj.addEventListener('load', function() { cropToViewBox(obj, vb); });
    }
  });
}

function computeViewBoxFromEdge() {
  var edgeObj = document.getElementById('layer-Edge-Cuts');
  var edgeSvg = edgeObj.contentDocument.querySelector('svg');
  var bbox = edgeSvg.getBBox();
  var margin = Math.max(bbox.width, bbox.height) * 0.05;
  return [bbox.x - margin, bbox.y - margin, bbox.width + margin * 2, bbox.height + margin * 2].join(' ');
}

var edgeObj = document.getElementById('layer-Edge-Cuts');
if (edgeObj.contentDocument && edgeObj.contentDocument.querySelector('svg')) {
  applyCropToAllLayers(computeViewBoxFromEdge());
} else {
  edgeObj.addEventListener('load', function() {
    applyCropToAllLayers(computeViewBoxFromEdge());
  });
}

applyZOrder();
</script>
</body>
</html>
"""


def board_layer_names(pcb: Path) -> set[str]:
    """Enabled layer names (canonical + friendly) from the .kicad_pcb layers table."""
    text = pcb.read_text()
    names = set()
    for m in re.finditer(r'\(\d+\s+"([\w.]+)"\s+\w+(?:\s+"([\w.]+)")?\)', text):
        names.add(m.group(1))
        if m.group(2):
            names.add(m.group(2))
    return names


def export_gerbview(out: Path, proj_name: str, pcb: Path) -> None:
    """Generate <proj>_gerbview.html plus a companion <proj>_gerbview/ folder of per-layer SVGs."""
    available = board_layer_names(pcb)
    layers = [l for l in GERBVIEW_LAYERS if l[0] == "Edge.Cuts" or l[0] in available]

    gerbview_dir = out / f"{proj_name}_gerbview"
    gerbview_dir.mkdir()

    run(["kicad-cli", "pcb", "export", "svg",
         "--output", str(gerbview_dir) + "/",
         "--layers", ",".join(label for label, *_ in layers),
         "--mode-multi",
         "--exclude-drawing-sheet",
         "--fit-page-to-board",
         str(pcb)])

    def svg_filename(label: str) -> str:
        return f"{pcb.stem}-{label.replace('.', '_')}.svg"

    checkboxes = "\n  ".join(
        f'<label class="layer-label" style="--c:#{color}">'
        f'<input type="checkbox" {"checked" if default_on else ""} '
        f'onchange="toggleLayer(this)" data-layer="{label}"> {label}</label>'
        for label, color, default_on, _ in layers
    )

    objects = "\n    ".join(
        f'<object id="layer-{label.replace(".", "-")}" class="pcb-layer{"" if default_on else " hidden"}" '
        f'style="opacity:{opacity};" '
        f'type="image/svg+xml" data="{proj_name}_gerbview/{svg_filename(label)}"></object>'
        for label, color, default_on, opacity in layers
    )

    layer_order_js = "[" + ", ".join(f'"{label.replace(".", "-")}"' for label, *_ in layers) + "]"

    html = (GERBVIEW_TEMPLATE
            .replace("__PROJ_NAME__", proj_name)
            .replace("__CHECKBOXES__", checkboxes)
            .replace("__OBJECTS__", objects)
            .replace("__LAYER_ORDER_JS__", layer_order_js))

    html_path = out / f"{proj_name}_gerbview.html"
    html_path.write_text(html)
    print(f"Saved: {html_path}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Generate KiCad fabrication deliverables."
    )
    parser.add_argument("projectname",
                        help="Base filename of the .kicad_sch/.kicad_pcb files (no extension)")
    parser.add_argument("--include-source", action="store_true",
                        help="Zip minimal source files into the output folder")
    args = parser.parse_args()

    proj_file = args.projectname
    proj_name = proj_file.replace(" ", "_")

    sch = Path(f"{proj_file}.kicad_sch")
    pcb = Path(f"{proj_file}.kicad_pcb")

    timestamp = datetime.now().strftime("%Y-%m-%d-%H%M%S")

    # Create _mfg output directory if it doesn't exist
    Path("_mfg").mkdir(exist_ok=True)

    # Create per-run output directory
    out = Path(f"{proj_name}_fab-outputs_{timestamp}")
    out.mkdir()

    # -- ERC / DRC -----------------------------------------------------------
    run(["kicad-cli", "pcb", "drc",
         "--output",            str(out / "drc.txt"),
         "--schematic-parity",
         "--severity-error", "--severity-warning",
         str(pcb)])

    run(["kicad-cli", "sch", "erc",
         "--output",        str(out / "erc.txt"),
         "--severity-error", "--severity-warning",
         str(sch)])

    # -- Schematic PDFs ------------------------------------------------------
    run(["kicad-cli", "sch", "export", "pdf",
         "--output", str(out / f"{proj_name}_schematic_bw.pdf"),
         "--theme",  "Black-White",
         str(sch)])

    run(["kicad-cli", "sch", "export", "pdf",
         "--output", str(out / f"{proj_name}_schematic_color.pdf"),
         "--theme",  "wDark",
         str(sch)])

    # -- BOMs ----------------------------------------------------------------
    # CM BOM
    run(["kicad-cli", "sch", "export", "bom",
         "--output", str(out / f"{proj_name}_BOM_CM.csv"),
         "--fields", "${QUANTITY},Reference,Value,Description,${FOOTPRINT_NAME},MFG,MPN,LCSC,Sub,Note",
         "--labels", "Qty, Refs, Value, Description, Footprint, MFG, MPN, LCSC#, Substitute, Note",
         "--group-by", "Value",
         "--ref-range-delimiter", "",
         "--exclude-dnp",
         str(sch)])

    # ENG / Costed BOM
    run(["kicad-cli", "sch", "export", "bom",
         "--output", str(out / f"{proj_name}_BOM_ENG.csv"),
         "--fields", "${QUANTITY},Reference,Value,Description,${FOOTPRINT_NAME},MFG,MPN,LCSC,Sub,Note,Price",
         "--labels", "Qty, Refs, Value, Description, Footprint, MFG, MPN, LCSC#, Substitute, Note, Price",
         "--group-by", "Value",
         "--ref-range-delimiter", "",
         "--exclude-dnp",
         str(sch)])

    # JLC BOM
    run(["kicad-cli", "sch", "export", "bom",
         "--output", str(out / f"{proj_name}_BOM_JLC.csv"),
         "--fields", "Reference,${FOOTPRINT_NAME},${QUANTITY},Value,LCSC",
         "--labels", "Designator, Footprint, Quantity, Value, LCSC Part #",
         "--group-by", "Value",
         "--ref-range-delimiter", "",
         "--exclude-dnp",
         str(sch)])

    # -- Netlist -------------------------------------------------------------
    run(["kicad-cli", "pcb", "export", "ipcd356",
         "--output", str(out / f"{proj_name}_netlist.d356"),
         str(pcb)])

    # -- Pick-and-place / CPL ------------------------------------------------
    positions_csv = out / f"{proj_name}_positions.csv"

    run(["kicad-cli", "pcb", "export", "pos",
         "--output",              str(positions_csv),
         "--format", "csv",
         "--units",  "mm",
         "--use-drill-file-origin",
         "--exclude-dnp",
         str(pcb)])

    convert_cpl_jlc(positions_csv, out / f"{proj_name}_CPL_JLC.csv")

    # -- Gerbers -------------------------------------------------------------
    gerber_dir = out / f"{proj_name}_gerbers"

    run(["kicad-cli", "pcb", "export", "gerbers",
         "--output", str(gerber_dir),
         "--layers", "F.Cu,In1.Cu,In2.Cu,B.Cu,F.Silkscreen,B.Silkscreen,"
                     "Edge.Cuts,F.Paste,B.Paste,F.Mask,B.Mask,User.2",
         str(pcb)])

    run(["kicad-cli", "pcb", "export", "drill",
         "--output", str(gerber_dir),
         str(pcb)])

    zip_directory(gerber_dir, out / f"{proj_name}_gerbers.zip")

    # -- Gerbview layer viewer ------------------------------------------------
    export_gerbview(out, proj_name, pcb)

    # -- Fab drawings --------------------------------------------------------
    run(["kicad-cli", "pcb", "export", "pdf",
         "--output", str(out / f"{proj_name}_drilldwg.pdf"),
         "--layers", "User.2,Edge.Cuts",
         "--ibt", "--sp", "--black-and-white",
         "--drill-shape-opt", "1",
         "--mode-single",
         str(pcb)])

    run(["kicad-cli", "pcb", "export", "pdf",
         "--output", str(out / f"{proj_name}_assy_front.pdf"),
         "--layers", "F.Fab,Edge.Cuts",
         "--ibt", "--sp", "--black-and-white", "--mode-single",
         str(pcb)])

    run(["kicad-cli", "pcb", "export", "pdf",
         "--output", str(out / f"{proj_name}_assy_back.pdf"),
         "--layers", "B.Fab,Edge.Cuts",
         "--mirror", "--ibt", "--sp", "--black-and-white", "--mode-single",
         str(pcb)])

    # -- Renders -------------------------------------------------------------
    run(["kicad-cli", "pcb", "render",
         "--output", str(out / f"{proj_name}_render_top.png"),
         "--side", "top", "--background", "opaque",
         str(pcb)])

    run(["kicad-cli", "pcb", "render",
         "--output", str(out / f"{proj_name}_render_bottom.png"),
         "--side", "bottom", "--background", "opaque",
         str(pcb)])

    # -- Provenance ----------------------------------------------------------
    write_provenance(out, sch, pcb, timestamp)

    # -- Optional source bundle ----------------------------------------------
    if args.include_source:
        bundle_source(out, proj_file, proj_name)

    # -- Move output bundle into _mfg ----------------------------------------
    shutil.move(str(out), "_mfg/")

    print(f"\nDeliverables saved to _mfg/{out}.")


if __name__ == "__main__":
    main()
